# StatPlay Football — Configuración para GitHub
# Copia este archivo como .env y rellena con tus valores reales

# Servidor
PORT=3000
NODE_ENV=production

# Base de Datos (MySQL)
DB_HOST=tu-servidor-db.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu-password-aqui
DB_NAME=statplay_db

# APIs de Terceros
FOOTBALL_API_KEY=tu-api-football-key
FOOTBALL_DATA_KEY=tu-football-data-token

# Frontend / CORS
FRONTEND_URL=https://tu-app.vercel.app

# Admin
ADMIN_KEY=tu-clave-secreta-para-admin
