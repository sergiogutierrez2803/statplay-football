# StatPlay Football — Variables de entorno
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas .env al repositorio

PORT=3000
NODE_ENV=production

# Base de datos MySQL (Railway provee estas variables automáticamente)
DB_HOST=your-mysql-host.railway.app
DB_USER=root
DB_PASS=your-secure-password
DB_NAME=statplay_db

# APIs externas
FOOTBALL_API_KEY=your-api-football-key
FOOTBALL_DATA_KEY=your-football-data-key

# CORS — URL del frontend en Vercel
FRONTEND_URL=https://your-app.vercel.app

# Clave secreta para endpoints admin (/api/admin/sync, /api/admin/status)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=your-random-secret-key-here

SOCCERSTATS_ENABLED=true
SOCCERSTATS_TIMEOUT_MS=15000
SOCCERSTATS_DELAY_MS=4000
SOCCERSTATS_USE_CORNERS=true
SOCCERSTATS_USE_OVER25=false
SOCCERSTATS_USE_BTTS=false
